# AWS — credenciais usadas por S3, SES e Lambda (região fixa em us-east-1)
# Em dev use AWS_ACCESS_KEY/AWS_SECRET_KEY; na Amplify use AMPLIFY_AWS_ACCESS_KEY/AMPLIFY_AWS_SECRET_KEY.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# Remetente verificado no SES (fallback: no-reply@solfy.tech)
SES_FROM=
# Defina como 1 para desabilitar o envio de e-mails
DISABLE_EMAIL_NOTIFICATIONS=
