LOCAL=
DATABASE_URL=
TOKEN_KEY=

# AWS / e-mail (SES) — usados para enviar o código de login
# Credenciais: em dev use AWS_ACCESS_KEY/AWS_SECRET_KEY; na Amplify use AMPLIFY_AWS_ACCESS_KEY/AMPLIFY_AWS_SECRET_KEY.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# Remetente verificado no SES (fallback: no-reply@solfy.tech)
SES_FROM=
# Defina como 1 para desabilitar o envio de e-mails (em dev o código é logado no servidor)
DISABLE_EMAIL_NOTIFICATIONS=
