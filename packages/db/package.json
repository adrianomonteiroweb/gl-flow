{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./repositories/*": "./src/repositories/*.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:introspect": "drizzle-kit introspect",
    "db:check": "drizzle-kit check:pg",
    "db:migrate": "tsx ./src/migrate.ts",
    "db:seed": "tsx ./src/seed.ts",
    "db:seed:account": "tsx ./src/seed-account.ts",
    "db:apply-pipelines": "tsx ./scripts/apply-pipelines-multitenant.ts",
    "test:cep-flow": "tsx ./src/test-cep-no-street-flow.ts",
    "db:apply-roles-member": "tsx ./scripts/apply-roles-member.ts",
    "db:apply-teams": "tsx ./scripts/apply-teams.ts"
  },
  "dependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/utils": "workspace:*",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.15.6"
  },
  "devDependencies": {
    "@types/pg": "^8.11.14",
    "drizzle-kit": "^0.31.1"
  }
}
