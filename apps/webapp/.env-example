# =============================================================
# Banco de dados
# =============================================================
# Local: defina LOCAL=1 para desabilitar SSL no cliente pg.
# Vercel/Neon: NÃO defina LOCAL (ou use 0) para manter o SSL exigido pelo Neon.
LOCAL=
# Local: postgres://user:password@localhost:5432/dbname
# Neon (staging): use a connection string POOLED (host com "-pooler") e sslmode=require.
# Ex.: postgres://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# =============================================================
# Auth (JWT do cookie linharesflow_DOC_AT)
# =============================================================
TOKEN_KEY=

# =============================================================
# AWS / e-mail (SES) — usados para enviar o código de login
# =============================================================
# Credenciais: em dev use AWS_ACCESS_KEY/AWS_SECRET_KEY; na Amplify use AMPLIFY_AWS_ACCESS_KEY/AMPLIFY_AWS_SECRET_KEY.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# Remetente verificado no SES (fallback: no-reply@solfy.tech)
SES_FROM=
# Defina como 1 para desabilitar o envio de e-mails (em dev/staging o código é logado no servidor)
DISABLE_EMAIL_NOTIFICATIONS=

# =============================================================
# Opcionais
# =============================================================
# Necessário apenas se reativar endpoints de cron (/api/cron/*). O Vercel Cron envia
# automaticamente o header Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
# Necessário apenas se usar criptografia de tokens externos (encryptToken). 64 chars hex (32 bytes).
WA_TOKEN_ENCRYPTION_KEY=
